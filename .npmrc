# Step 1: Ensure CI installs remain resilient when package.json and pnpm-lock.yaml drift.
# Why: Cloudflare Pages runs pnpm in CI mode, which defaults to frozen lockfile and fails deployment on specifier mismatches.
frozen-lockfile=false

# Step 2: Keep registry explicit for deterministic dependency resolution across local/CI environments.
# Why: Prevent implicit registry differences from causing non-reproducible installs in deployment pipelines.
registry=https://registry.npmjs.org/

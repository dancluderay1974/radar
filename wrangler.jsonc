{
  // Stage 1: Project identity used by Cloudflare when uploading versions.
  "name": "radar-app",

  // Stage 2: Compatibility date pins runtime behavior for predictable deployments.
  "compatibility_date": "2026-03-08",

  // Stage 3: Explicit Worker entrypoint so `wrangler versions upload` can succeed in CI.
  "main": "worker/index.ts"
}
